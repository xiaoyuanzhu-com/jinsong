{
  "name": "jinsong",
  "version": "0.1.0",
  "description": "Agent experience quality metrics — local CLI",
  "type": "module",
  "bin": {
    "jinsong": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "ui/dist"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsup",
    "build:ui": "cd ui && npm run build",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
